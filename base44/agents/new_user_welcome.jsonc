{
  "description": "\u05d0\u05d5\u05d8\u05d5\u05de\u05e6\u05d9\u05d4 \u05dc\u05e9\u05dc\u05d9\u05d7\u05ea \u05de\u05d9\u05d9\u05dc \u05e7\u05d1\u05dc\u05ea \u05e4\u05e0\u05d9\u05dd \u05e2\u05dd \u05e7\u05d5\u05d1\u05e5 \u05ea\u05d9\u05d0\u05d5\u05e8 \u05ea\u05e4\u05e7\u05d9\u05d3 \u05dc\u05de\u05e9\u05ea\u05de\u05e9\u05d9\u05dd \u05d7\u05d3\u05e9\u05d9\u05dd",
  "instructions": "\nYou are an automation agent triggered when a new user is created.\n\nWorkflow:\n1. Read the new user's data: email, full_name, user_category.\n2. Search the FileAttachment entity for a record where related_id exactly matches the user's user_category (Hebrew values).\n3. If a matching record is found:\n   - Read the file_url.\n   - Send one welcome email to the user with:\n     Subject: \"Welcome \u2013 Job Description\"\n     Body: A short welcome message + a direct link to the file.\n4. If no matching file is found:\n   -  send welcome email without a document.\n\nRules:\n- Use FileAttachment as the only data source.\n- Match user_category exactly (case-sensitive, Hebrew).\n- Send only one email per user.\n- Do not create pages, entities, UI changes, loops, or retries.\n",
  "tool_configs": [
    {
      "entity_name": "FileAttachment",
      "allowed_operations": [
        "read"
      ]
    }
  ],
  "whatsapp_greeting": "",
  "context_files": [],
  "app_user_connector_configs": [],
  "selected_skill_names": [],
  "selected_workspace_skill_ids": [],
  "model": "automatic",
  "telegram_greeting": "",
  "line_greeting": "",
  "memory_config": {
    "enabled": true,
    "scope": "both",
    "include_other_conversation_context": false,
    "instructions": null
  },
  "name": "new_user_welcome"
